# ---- hinge-autoswiper config ----
# Copy this file to ".env" and edit. install.sh and run.sh read it.

# Which LLM brain drives the agent.
# LOCAL (free, private, needs RAM):   ollama
# CLOUD (cheap, fast, needs API key): openai | anthropic | google
GOOSE_PROVIDER=ollama

# Model name for the chosen provider.
#   ollama    -> gemma3:4b (8GB RAM)  |  gemma3:12b (16GB)  |  gemma3:27b (32GB+)
#   openai    -> gpt-4o-mini (cheap, vision)
#   anthropic -> claude-haiku-4-5 (cheap, vision)
#   google    -> gemini-2.0-flash (cheap, vision)
GOOSE_MODEL=gemma3:4b

# Ollama server (only used when GOOSE_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434

# If using a cloud provider, put the key here (leave blank for ollama).
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# ---- swipe behaviour ----
# like_only | like_with_comment | full_access
MODE=like_only
# Stop after this many profiles per session.
SESSION_CAP=40
# Min/max seconds between actions (human-like pacing).
MIN_DELAY=3
MAX_DELAY=8
# Run the 5-profile warmup that asks your taste first (true/false).
WARMUP=true
